class Solution:
    def sumOfLeftLeaves(self, root):
        if not root:
            return 0

        def is_leaf(node):
            return node and not node.left and not node.right

        total = 0

        def dfs(node):
            nonlocal total
            if not node:
                return

            # kiểm tra lá trái
            if is_leaf(node.left):
                total += node.left.val

            dfs(node.left)
            dfs(node.right)

        dfs(root)
        return total
