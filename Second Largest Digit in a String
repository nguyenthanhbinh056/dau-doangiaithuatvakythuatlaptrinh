class Solution(object):
    def secondHighest(self, s):
        """
        :type s: str
        :rtype: int
        """
        digits = set()
        
        for c in s:
            if c.isdigit():
                digits.add(int(c))
        
        digits = sorted(digits, reverse=True)
        
        if len(digits) < 2:
            return -1
        else:
            return digits[1]
