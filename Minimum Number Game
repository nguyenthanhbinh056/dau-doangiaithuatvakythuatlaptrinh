        """
        :type nums: List[int]
        :rtype: List[int]
        """
class Solution(object):
    def numberGame(self, nums):
        nums.sort()  # sắp xếp tăng dần
        arr = []
        n = len(nums)
        
        # Lặp qua từng cặp phần tử (Alice, Bob)
        for i in range(0, n, 2):
            alice = nums[i]      # Alice lấy phần tử nhỏ nhất
            bob = nums[i+1]      # Bob lấy phần tử tiếp theo
            arr.append(bob)      # Bob thêm trước
            arr.append(alice)    # Alice thêm sau
            
        return arr        
