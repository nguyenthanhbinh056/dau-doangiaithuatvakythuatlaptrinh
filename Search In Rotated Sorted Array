class Solution:
    def search(self, nums, target):
        left = 0
        right = len(nums) - 1

        while left <= right:
            mid = (left + right) // 2

            if nums[mid] == target:
                return mid

            # nửa bên trái đã được sắp xếp
            if nums[left] <= nums[mid]:

                # target nằm trong nửa trái
                if nums[left] <= target < nums[mid]:
                    right = mid - 1
                else:
                    left = mid + 1

            # nửa bên phải đã được sắp xếp
            else:

                # target nằm trong nửa phải
                if nums[mid] < target <= nums[right]:
                    left = mid + 1
                else:
                    right = mid - 1

        return -1
