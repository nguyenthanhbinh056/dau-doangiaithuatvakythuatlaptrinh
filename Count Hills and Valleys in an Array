        """
        :type nums: List[int]
        :rtype: int
        """
class Solution(object):
    def countHillValley(self, nums):
        # Loại bỏ các phần tử liên tiếp giống nhau
        nums = [nums[i] for i in range(len(nums)) if i == 0 or nums[i] != nums[i-1]]
        # Đếm đỉnh và thung lũng
        return sum(1 for i in range(1, len(nums)-1) if (nums[i] > nums[i-1] and nums[i] > nums[i+1]) or (nums[i] < nums[i-1] and nums[i] < nums[i+1]))     
