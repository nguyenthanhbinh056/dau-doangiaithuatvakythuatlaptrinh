class Solution(object):
    def sumOfUnique(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        count = {}
        
        for num in nums:
            count[num] = count.get(num, 0) + 1
        
        total = 0
        for num in count:
            if count[num] == 1:
                total += num
        
        return total
