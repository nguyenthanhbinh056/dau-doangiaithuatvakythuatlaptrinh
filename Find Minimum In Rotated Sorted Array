class Solution:
    def findMin(self, nums):
        left = 0
        right = len(nums) - 1

        while left < right:
            mid = (left + right) // 2

            # phần nhỏ nhất nằm bên phải
            if nums[mid] > nums[right]:
                left = mid + 1
            else:
                # phần nhỏ nhất nằm bên trái hoặc chính mid
                right = mid

        return nums[left]
