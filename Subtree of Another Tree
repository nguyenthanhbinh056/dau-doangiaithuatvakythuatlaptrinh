class Solution:
    def isSubtree(self, root, subRoot):

        def isSameTree(p, q):
            if not p and not q:
                return True
            if not p or not q:
                return False
            if p.val != q.val:
                return False

            return (isSameTree(p.left, q.left) and
                    isSameTree(p.right, q.right))

        def dfs(node):
            if not node:
                return False

            # nếu cây tại node này giống subRoot
            if isSameTree(node, subRoot):
                return True

            return dfs(node.left) or dfs(node.right)

        return dfs(root)
