class Solution:
    def binaryTreePaths(self, root):
        result = []

        def dfs(node, path):
            if not node:
                return

            path.append(str(node.val))

            # nếu là lá
            if not node.left and not node.right:
                result.append("->".join(path))
            else:
                dfs(node.left, path)
                dfs(node.right, path)

            path.pop()  # backtrack

        dfs(root, [])
        return result
