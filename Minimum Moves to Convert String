class Solution:
    def minimumMoves(self, s: str) -> int:
        s = list(s)
        n = len(s)
        moves = 0

        i = 0
        while i < n:
            if s[i] == 'X':
                moves += 1
                # flip 3 ký tự
                for j in range(i, min(i + 3, n)):
                    s[j] = 'O'
                i += 3
            else:
                i += 1

        return moves
