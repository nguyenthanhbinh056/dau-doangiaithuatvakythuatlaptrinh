class Solution(object):
    def groupAnagrams(self, strs):
        """
        :type strs: List[str]
        :rtype: List[List[str]]
        """
        groups = {}
        
        for s in strs:
            key = tuple(sorted(s))  # chuẩn hoá chuỗi
            groups.setdefault(key, []).append(s)
        
        return list(groups.values())
