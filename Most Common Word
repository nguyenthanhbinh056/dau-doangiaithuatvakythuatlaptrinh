class Solution(object):
    def mostCommonWord(self, paragraph, banned):
        """
        :type paragraph: str
        :type banned: List[str]
        :rtype: str
        """
        import re
        
        paragraph = paragraph.lower()
        words = re.findall(r'\w+', paragraph)
        
        banned = set(banned)
        count = {}
        res = ""
        max_count = 0
        
        for w in words:
            if w not in banned:
                count[w] = count.get(w, 0) + 1
                
                if count[w] > max_count:
                    max_count = count[w]
                    res = w
        
        return res
