class Solution:
    def isHappy(self, n):
        def get_next(x):
            total = 0
            while x > 0:
                digit = x % 10
                total += digit * digit
                x //= 10
            return total

        seen = set()

        while n != 1:
            if n in seen:
                return False
            seen.add(n)
            n = get_next(n)

        return True
