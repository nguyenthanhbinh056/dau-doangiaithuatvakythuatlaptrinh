class Solution(object):
    def distributeCandies(self, candies, num_people):
        """
        :type candies: int
        :type num_people: int
        :rtype: List[int]
        """
        res = [0] * num_people
        give = 1
        i = 0
        
        while candies > 0:
            person = i % num_people
            
            if candies >= give:
                res[person] += give
                candies -= give
            else:
                res[person] += candies
                candies = 0
            
            give += 1
            i += 1
        
        return res
