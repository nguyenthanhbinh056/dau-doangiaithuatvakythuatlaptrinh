class Solution:
    def dailyTemperatures(self, temperatures):
        n = len(temperatures)
        answer = [0] * n
        stack = []  # lưu index

        for i in range(n):
            # tìm ngày lạnh hơn trước đó
            while stack and temperatures[i] > temperatures[stack[-1]]:
                idx = stack.pop()
                answer[idx] = i - idx

            stack.append(i)

        return answer
