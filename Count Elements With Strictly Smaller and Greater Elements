class Solution(object):
    def countElements(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
class Solution(object):
    def countElements(self, nums):
        min_val = min(nums)
        max_val = max(nums)
        count = 0
        for x in nums:
            if x != min_val and x != max_val:
                count += 1
        return count        
