    def numRescueBoats(self, people, limit):
        """
        :type people: List[int]
        :type limit: int
        :rtype: int
        """
class Solution(object):
    def numRescueBoats(self, people, limit):
        people.sort()
        i, j = 0, len(people) - 1
        boats = 0
        
        while i <= j:
            if people[i] + people[j] <= limit:
                i += 1  # người nhẹ nhất đi cùng người nặng nhất
            j -= 1      # người nặng nhất luôn đi
            boats += 1
        
        return boats        
