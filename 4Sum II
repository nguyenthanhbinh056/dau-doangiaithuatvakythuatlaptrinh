class Solution(object):
    def fourSumCount(self, nums1, nums2, nums3, nums4):
        """
        :type nums1: List[int]
        :type nums2: List[int]
        :type nums3: List[int]
        :type nums4: List[int]
        :rtype: int
        """
        count = {}
        
        # Lưu tổng của nums1 + nums2
        for a in nums1:
            for b in nums2:
                count[a + b] = count.get(a + b, 0) + 1
        
        result = 0
        
        # Kiểm tra với nums3 + nums4
        for c in nums3:
            for d in nums4:
                target = -(c + d)
                if target in count:
                    result += count[target]
        
        return result
