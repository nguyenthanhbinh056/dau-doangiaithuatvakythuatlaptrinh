class Solution:
    def guessNumber(self, n: int) -> int:
        left = 1
        right = n

        while left <= right:
            mid = (left + right) // 2

            result = guess(mid)

            if result == 0:
                return mid

            elif result == 1:
                # số cần tìm lớn hơn mid
                left = mid + 1

            else:
                # số cần tìm nhỏ hơn mid
                right = mid - 1
