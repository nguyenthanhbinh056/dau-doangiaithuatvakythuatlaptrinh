class Solution(object):
    def areOccurrencesEqual(self, s):
        """
        :type s: str
        :rtype: bool
        """
        count = {}
        
        for c in s:
            count[c] = count.get(c, 0) + 1
        
        values = list(count.values())
        
        for v in values:
            if v != values[0]:
                return False
        
        return True
